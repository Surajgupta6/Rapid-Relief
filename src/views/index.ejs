            <a href="#" class="text-white me-2"><i class="fab fa-twitter"></i></a>
            <a href="#" class="text-white me-2"><i class="fab fa-instagram"></i></a>
            <a href="#" class="text-white"><i class="fab fa-linkedin-in"></i></a>
          </div>
        </div>
      </div>
      <hr class="my-4">
      <div class="text-center">
        <p class="mb-0" data-i18n="copyright">&copy; 2023 Rapid Relief. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <button id="chatbot-btn" title="Chat with us!">
    <i class="fas fa-comment"></i>
  </button>
  <div id="chatbot-window">
    <div id="chatbot-header">Rapid Relief Bot</div>
    <div id="chatbot-messages"></div>
    <div id="chatbot-input-area">
      <input id="chatbot-input" type="text" placeholder="Type your message..." disabled>
      <button id="chatbot-send" disabled>Send</button>
    </div>
  </div>
  <style>
    #chatbot-btn {
      position: fixed;
      bottom: 30px;
      right: 30px;
      background: #dc3545;
      color: #fff;
      border: none;
      border-radius: 50%;
      width: 60px;
      height: 60px;
      font-size: 2rem;
      box-shadow: 0 4px 16px rgba(0,0,0,0.2);
      z-index: 99999;
      cursor: pointer;
    }
    #chatbot-window {
      display: none;
      position: fixed;
      bottom: 100px;
      right: 30px;
      width: 320px;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 32px rgba(0,0,0,0.2);
      z-index: 10000;
      overflow: hidden;
      flex-direction: column;
    }
    #chatbot-header {
      background: #dc3545;
      color: #fff;
      padding: 12px;
      font-weight: bold;
      text-align: center;
    }
    #chatbot-messages {
      padding: 16px;
      height: 180px;
      overflow-y: auto;
      font-size: 1rem;
    }
    #chatbot-input-area {
      display: flex;
      border-top: 1px solid #eee;
    }
    #chatbot-input {
      flex: 1;
      border: none;
      padding: 10px;
      font-size: 1rem;
    }
    #chatbot-send {
      background: #dc3545;
      color: #fff;
      border: none;
      padding: 0 16px;
      cursor: pointer;
    }
  </style>
  <script>
    const chatbotBtn = document.getElementById('chatbot-btn');
    const chatbotWindow = document.getElementById('chatbot-window');
    const chatbotMessages = document.getElementById('chatbot-messages');
    const chatbotInput = document.getElementById('chatbot-input');
    const chatbotSend = document.getElementById('chatbot-send');

    chatbotBtn.onclick = () => {
      chatbotWindow.style.display = chatbotWindow.style.display === 'flex' ? 'none' : 'flex';
      chatbotWindow.style.flexDirection = 'column';
      if (chatbotMessages.innerHTML === '') {
        botMessage(`Hello! 👋<br>
Welcome to Rapid Relief.<br><br>
<b>How to get started:</b><br>
1. <b>Register an account</b> by clicking the <b>Sign Up</b> button at the top right.<br>
2. After registering, <b>log in</b> to your account.<br>
3. Go to your <b>dashboard</b> and fill out the booking form with patient and location details.<br>
4. Click <b>Book Ambulance Now</b> to request an ambulance.<br>
5. You can <b>track your booking status</b> and ambulance location in real-time from your dashboard.<br><br>
If you need help at any step, just type your question below!`);
      }
    };

    function botMessage(msg) {
      chatbotMessages.innerHTML += `<div style='margin-bottom:10px;'><b>Bot:</b> ${msg}</div>`;
      chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
    }

    function userMessage(msg) {
      chatbotMessages.innerHTML += `<div style='text-align:right;margin-bottom:10px;'><b>You:</b> ${msg}</div>`;
      chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
    }

    chatbotInput.onkeydown = function(e) {
      if (e.key === 'Enter') chatbotSend.click();
    };

    chatbotSend.onclick = function() {
      const msg = chatbotInput.value.trim();
      if (!msg) return;
      userMessage(msg);
      chatbotInput.value = '';
      setTimeout(() => {
        // More detailed scripted responses
        if (/register|sign ?up/i.test(msg)) {
          botMessage(`To register:<br>
1. Click the <b>Sign Up</b> button at the top right of the page.<br>
2. Choose your role (User, Driver, or Hospital) and fill in the required details.<br>
3. Submit the form. You will receive a confirmation message.<br>
4. After registering, use your credentials to log in.<br><br>
<b>Tip:</b> If you have trouble registering, make sure all required fields are filled and your email is valid.`);
        } else if (/book|ambulance|booking/i.test(msg)) {
          botMessage(`To book an ambulance:<br>
1. Log in to your account.<br>
2. Go to your <b>dashboard</b>.<br>
3. Fill out the booking form with the patient's name, contact, medical condition, and pickup location.<br>
4. Click <b>Book Ambulance Now</b>.<br>
5. You will see your booking in the <b>Recent Bookings</b> section and can track its status.<br><br>
<b>Note:</b> You can also view your full booking history from the <b>My Bookings</b> page.`);
        } else if (/track|status|where|location/i.test(msg)) {
          botMessage(`To track your ambulance:<br>
1. After making a booking, go to your <b>dashboard</b>.<br>
2. Your active booking will show real-time status and ambulance location on the map.<br>
3. You will also receive updates as the status changes (e.g., accepted, in progress, completed).`);
        } else if (/hello|hi|hey/i.test(msg)) {
          botMessage('Hello! How can I assist you today? You can ask about registration, booking, or tracking your ambulance.');
        } else {
          botMessage('I am here to help you register, make bookings, and track your ambulance. Try asking about registration, booking, or tracking!');
        }
      }, 600);
    };

    // Enable input for interactive bot
    chatbotInput.disabled = false;
    chatbotSend.disabled = false;
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/translations.js"></script>
  <script src="/js/main.js"></script>
</body>
</html> 