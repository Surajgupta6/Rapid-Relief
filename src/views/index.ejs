          <p class="lead mb-4" data-i18n="heroSubtitle">Book an ambulance in just a few clicks. Our real-time tracking ensures you know exactly when help will arrive.</p>
          <div class="d-flex flex-column flex-sm-row gap-3 justify-content-lg-start justify-content-center">
            <a href="/book-now" class="btn btn-danger btn-lg px-4" data-i18n="bookNow">Book Ambulance Now</a>
            <div class="dropdown">
              <button class="btn btn-outline-light btn-lg px-4 dropdown-toggle" type="button" id="registerDropdown" data-bs-toggle="dropdown">
                Register As
              </button>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/register"><i class="fas fa-user me-2"></i> Register as User</a></li>
                <li><a class="dropdown-item" href="/register-driver"><i class="fas fa-ambulance me-2"></i> Register as Driver</a></li>
