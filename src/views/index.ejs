            <div class="card-body text-center p-4">
              <div class="icon-box mb-4">
                <i class="fas fa-heartbeat text-danger fa-3x"></i>
              </div>
              <h3 class="card-title h5 fw-bold" data-i18n="service1Title">Emergency Response</h3>
              <p class="card-text" data-i18n="service1Text">Quick response times for medical emergencies with fully equipped ambulances.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
              <div class="icon-box mb-4">
                <i class="fas fa-hospital-user text-danger fa-3x"></i>
              </div>
              <h3 class="card-title h5 fw-bold" data-i18n="service2Title">Patient Transfer</h3>
              <p class="card-text" data-i18n="service2Text">Safe and comfortable transportation between healthcare facilities.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
              <div class="icon-box mb-4">
                <i class="fas fa-map-marked-alt text-danger fa-3x"></i>
              </div>
              <h3 class="card-title h5 fw-bold" data-i18n="service3Title">Real-time Tracking</h3>
              <p class="card-text" data-i18n="service3Text">Monitor the ambulance location in real-time with our GPS tracking system.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section id="how-it-works" class="py-5 bg-light">
    <div class="container">
      <div class="text-center mb-5">
        <h2 class="display-5 fw-bold text-danger" data-i18n="howItWorksTitle">How It Works</h2>
        <p class="lead" data-i18n="howItWorksSubtitle">Simple steps to book an ambulance</p>
      </div>
      <div class="row">
        <div class="col-md-3">
          <div class="text-center mb-4">
            <div class="step-circle mx-auto mb-3">1</div>
            <h4 data-i18n="step1Title">Register</h4>
            <p data-i18n="step1Text">Create an account to get started</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="text-center mb-4">
            <div class="step-circle mx-auto mb-3">2</div>
            <h4 data-i18n="step2Title">Book Ambulance</h4>
            <p data-i18n="step2Text">Enter location and patient details</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="text-center mb-4">
            <div class="step-circle mx-auto mb-3">3</div>
            <h4 data-i18n="step3Title">Track Status</h4>
            <p data-i18n="step3Text">Monitor ambulance location in real-time</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="text-center mb-4">
            <div class="step-circle mx-auto mb-3">4</div>
            <h4 data-i18n="step4Title">Safe Journey</h4>
            <p data-i18n="step4Text">Reach your destination safely</p>
          </div>
        </div>
      </div>
      <div class="text-center mt-4">
        <a href="/register" class="btn btn-danger btn-lg" data-i18n="getStarted">Get Started Now</a>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-5">
    <div class="container">
      <div class="row">
        <div class="col-lg-6">
          <h2 class="display-5 fw-bold text-danger mb-4" data-i18n="contactTitle">Contact Us</h2>
          <p class="lead mb-4" data-i18n="contactSubtitle">Have questions or need assistance? We're here to help!</p>
          <ul class="list-unstyled contact-info">
            <li class="mb-3"><i class="fas fa-phone text-danger me-2"></i> <span data-i18n="emergency">Emergency</span>: <strong>1-800-RAPIDRELIEF</strong></li>
            <li class="mb-3"><i class="fas fa-envelope text-danger me-2"></i> <span data-i18n="email">Email</span>: support@rapidrelief.com</li>
            <li class="mb-3"><i class="fas fa-map-marker-alt text-danger me-2"></i> <span data-i18n="address">Address</span>: 123 Healthcare Avenue, Medical City</li>
          </ul>
        </div>
        <div class="col-lg-6">
          <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
              <h3 class="h4 mb-4" data-i18n="sendMessage">Send a Message</h3>
              <form>
                <div class="mb-3">
                  <input type="text" class="form-control" data-i18n="yourName" placeholder="Your Name" required>
                </div>
                <div class="mb-3">
                  <input type="email" class="form-control" data-i18n="yourEmail" placeholder="Your Email" required>
                </div>
                <div class="mb-3">
                  <textarea class="form-control" rows="4" data-i18n="yourMessage" placeholder="Your Message" required></textarea>
                </div>
                <button type="submit" class="btn btn-danger" data-i18n="send">Send Message</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-dark text-white py-4">
    <div class="container">
      <div class="row">
        <div class="col-md-6">
          <h3 class="h5 mb-3"><i class="fas fa-ambulance me-2"></i> <span data-i18n="brandName">Rapid Relief</span></h3>
          <p data-i18n="footerTagline">Providing fast and reliable emergency medical services.</p>
        </div>
        <div class="col-md-3">
          <h5 class="mb-3" data-i18n="quickLinks">Quick Links</h5>
          <ul class="list-unstyled">
            <li><a href="/" class="text-white-50 text-decoration-none" data-i18n="home">Home</a></li>
            <li><a href="/about" class="text-white-50 text-decoration-none" data-i18n="aboutUs">About Us</a></li>
            <li><a href="/services" class="text-white-50 text-decoration-none" data-i18n="services">Services</a></li>
