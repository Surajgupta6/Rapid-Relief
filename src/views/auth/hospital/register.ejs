<%- include('../../partials/header') %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">Hospital Registration</h3>
                </div>
                <div class="card-body">
                    <% if (error) { %>
                        <div class="alert alert-danger" role="alert">
                            <%= error %>
                        </div>
                    <% } %>
                    <form action="/hospital/register" method="POST">
                        <div class="form-group mb-3">
                            <label for="name">Hospital Name</label>
                            <input type="text" class="form-control" id="name" name="name" required>
                        </div>
                        <div class="form-group mb-3">
                            <label for="email">Email</label>
                            <input type="email" class="form-control" id="email" name="email" required>
                        </div>
                        <div class="form-group mb-3">
                            <label for="password">Password</label>
                            <input type="password" class="form-control" id="password" name="password" required>
                        </div>
                        <div class="form-group mb-3">
                            <label for="confirmPassword">Confirm Password</label>
                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
                        </div>
                        <div class="form-group mb-3">
                            <label for="contactNumber">Contact Number</label>
                            <input type="tel" class="form-control" id="contactNumber" name="contactNumber" required>
                        </div>
                        <div class="form-group mb-3">
                            <label for="address">Address</label>
                            <textarea class="form-control" id="address" name="address" rows="3" required></textarea>
                        </div>
                        <div class="form-group mb-3">
                            <label for="licenseNumber">License Number</label>
                            <input type="text" class="form-control" id="licenseNumber" name="licenseNumber" required>
                        </div>
                        
                        <h5 class="mt-4">Bed Capacity</h5>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label for="generalWardCapacity">General Ward Capacity</label>
                                    <input type="number" class="form-control" id="generalWardCapacity" name="generalWard[capacity]" required>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label for="opdCapacity">OPD Capacity</label>
                                    <input type="number" class="form-control" id="opdCapacity" name="opd[capacity]" required>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label for="emergencyCapacity">Emergency Department Capacity</label>
                                    <input type="number" class="form-control" id="emergencyCapacity" name="emergencyDepartment[capacity]" required>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label for="generalWardAvailable">General Ward Available Beds</label>
                                    <input type="number" class="form-control" id="generalWardAvailable" name="generalWard[availableBeds]" required>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label for="opdAvailable">OPD Available Beds</label>
                                    <input type="number" class="form-control" id="opdAvailable" name="opd[availableBeds]" required>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label for="emergencyAvailable">Emergency Department Available Beds</label>
                                    <input type="number" class="form-control" id="emergencyAvailable" name="emergencyDepartment[availableBeds]" required>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Register</button>
                        </div>
                    </form>
                    <div class="text-center mt-3">
                        <p>Already have an account? <a href="/hospital/login">Login</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %> 