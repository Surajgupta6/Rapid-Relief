<!DOCTYPE html>
<html lang="<%= getLocale() %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= __('register.pageTitle') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
      <a class="navbar-brand" href="/">
        <i class="fas fa-ambulance me-2"></i>
        <strong><%= __('nav.brand') %></strong>
      </a>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/"><%= __('nav.home') %></a></li>
          <li class="nav-item"><a class="nav-link btn btn-outline-light ms-2" href="/login"><%= __('nav.login') %></a></li>
          <li class="nav-item"><a class="nav-link btn btn-light text-primary ms-2" href="/register"><%= __('nav.register') %></a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="languageDropdown" role="button" data-bs-toggle="dropdown">
              <i class="fas fa-globe"></i>
            </a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/change-language/en">English</a></li>
              <li><a class="dropdown-item" href="/change-language/hi">हिंदी</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-6">
        <div class="card shadow">
          <div class="card-header bg-primary text-white">
            <h3 class="mb-0"><%= __('register.title') %></h3>
          </div>
          <div class="card-body">
            <div id="errorAlert" class="alert alert-danger d-none" role="alert">
              <%= __('register.errors.general') %>
            </div>
            
            <% if (locals.message) { %>
              <div class="alert alert-success" role="alert">
                <%= message %>
              </div>
            <% } %>
            
            <form id="registerForm">
              <div class="mb-3">
                <label for="name" class="form-label"><%= __('register.nameLabel') %></label>
                <input type="text" class="form-control" id="name" name="name" required>
              </div>
              
              <div class="mb-3">
                <label for="email" class="form-label"><%= __('register.emailLabel') %></label>
                <input type="email" class="form-control" id="email" name="email" required>
              </div>
              
              <div class="mb-3">
                <label for="phone" class="form-label"><%= __('register.phoneLabel') %></label>
                <input type="tel" class="form-control" id="phone" name="phone" required>
              </div>
              
              <div class="mb-3">
                <label for="address" class="form-label"><%= __('register.addressLabel') %></label>
                <textarea class="form-control" id="address" name="address" rows="2" required></textarea>
              </div>
              
              <div class="mb-3">
                <label for="password" class="form-label"><%= __('register.passwordLabel') %></label>
                <input type="password" class="form-control" id="password" name="password" minlength="8" required>
                <div class="form-text"><%= __('register.passwordHelp') %></div>
              </div>
              
              <div class="mb-3">
                <label for="confirmPassword" class="form-label"><%= __('register.confirmPasswordLabel') %></label>
                <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
              </div>
              
              <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary"><%= __('register.submitButton') %></button>
              </div>
            </form>
            
            <div class="mt-3 text-center">
              <p><%= __('register.haveAccount') %> <a href="/login"><%= __('register.loginHere') %></a></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const registerForm = document.getElementById('registerForm');
      const errorAlert = document.getElementById('errorAlert');
      
      registerForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        // Validate password match
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirmPassword').value;
        
        if (password !== confirmPassword) {
          errorAlert.textContent = '<%= __('register.errors.passwordMatch') %>';
          errorAlert.classList.remove('d-none');
          return;
        }
        
        // Get form data
        const formData = {
          name: document.getElementById('name').value,
          email: document.getElementById('email').value,
          phone: document.getElementById('phone').value,
          address: document.getElementById('address').value,
          password: password,
          role: 'user'
        };
        
        try {
          const response = await fetch('/auth/register', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
          });
          
          const data = await response.json();
          
          if (response.ok) {
            window.location.href = '/user/dashboard';
          } else {
            errorAlert.textContent = data.message || '<%= __('register.errors.tryAgain') %>';
            errorAlert.classList.remove('d-none');
          }
        } catch (err) {
          console.error('Registration error:', err);
          errorAlert.textContent = '<%= __('register.errors.tryLater') %>';
          errorAlert.classList.remove('d-none');
        }
      });
    });
  </script>
</body>
</html> 