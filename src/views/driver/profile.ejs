<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile | Driver Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-danger">
    <div class="container">
      <a class="navbar-brand" href="/driver/dashboard">
        <i class="fas fa-ambulance me-2"></i>
        <strong>Rapid Relief</strong>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/driver/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/driver/bookings">Bookings</a></li>
          <li class="nav-item"><a class="nav-link active" href="/driver/profile">Profile</a></li>
        </ul>
        <div class="d-flex">
          <span class="navbar-text me-3">
            <i class="fas fa-user-circle me-1"></i> <span id="driverName">Driver</span>
          </span>
          <a href="/auth/logout" class="btn btn-outline-light btn-sm">
            <i class="fas fa-sign-out-alt me-1"></i> Logout
          </a>
        </div>
      </div>
    </div>
  </nav>

  <div class="container py-4">
    <div class="row">
      <div class="col-md-4">
        <!-- Profile Summary Card -->
        <div class="card shadow-sm mb-4">
          <div class="card-body text-center">
            <div class="mb-3">
              <i class="fas fa-user-circle fa-5x text-danger"></i>
            </div>
            <h5 class="card-title mb-0" id="profileName">Loading...</h5>
            <p class="text-muted small mb-3" id="profileEmail"></p>
            <div class="d-grid">
              <button class="btn btn-outline-danger" type="button" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                <i class="fas fa-edit me-2"></i>Edit Profile
              </button>
            </div>
          </div>
        </div>

        <!-- Stats Card -->
        <div class="card shadow-sm">
          <div class="card-body">
            <h6 class="card-title mb-3">Statistics</h6>
            <div class="row text-center">
              <div class="col-6 mb-3">
                <h3 class="mb-1" id="totalTrips">0</h3>
                <p class="text-muted mb-0 small">Total Trips</p>
              </div>
              <div class="col-6 mb-3">
                <h3 class="mb-1" id="rating">0.0</h3>
                <p class="text-muted mb-0 small">Rating</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-8">
        <!-- Vehicle Information Card -->
        <div class="card shadow-sm mb-4">
          <div class="card-body">
            <h5 class="card-title mb-4">Vehicle Information</h5>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label text-muted small">Registration Number</label>
                <p class="mb-0" id="registrationNumber">Loading...</p>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label text-muted small">Vehicle Model</label>
                <p class="mb-0" id="vehicleModel">Loading...</p>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label text-muted small">License Number</label>
                <p class="mb-0" id="licenseNumber">Loading...</p>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label text-muted small">Vehicle Capacity</label>
                <p class="mb-0" id="vehicleCapacity">Loading...</p>
              </div>
              <div class="col-12">
                <label class="form-label text-muted small">Special Features</label>
                <p class="mb-0" id="vehicleFeatures">Loading...</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Information Card -->
        <div class="card shadow-sm">
          <div class="card-body">
            <h5 class="card-title mb-4">Contact Information</h5>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label text-muted small">Phone Number</label>
                <p class="mb-0" id="phoneNumber">Loading...</p>
              </div>
              <div class="col-md-12 mb-3">
                <label class="form-label text-muted small">Address</label>
                <p class="mb-0" id="address">Loading...</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Profile Modal -->
  <div class="modal fade" id="editProfileModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Edit Profile</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="editProfileForm">
            <div class="mb-3">
              <label class="form-label">Phone Number</label>
              <input type="tel" class="form-control" id="editPhone" name="phone" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Address</label>
              <textarea class="form-control" id="editAddress" name="address" rows="2" required></textarea>
            </div>
            <div class="mb-3">
              <label class="form-label">Vehicle Model</label>
              <input type="text" class="form-control" id="editModel" name="model" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Vehicle Capacity</label>
              <input type="number" class="form-control" id="editCapacity" name="capacity" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Special Features (comma-separated)</label>
              <input type="text" class="form-control" id="editFeatures" name="features">
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-danger" id="saveProfileBtn">Save Changes</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Load profile data
      fetch('/driver/profile')
        .then(response => response.json())
        .then(data => {
          if (data.status === 'success') {
            const { driver } = data.data;
            const user = driver.user;

            // Update profile info
            document.getElementById('profileName').textContent = user.name;
            document.getElementById('profileEmail').textContent = user.email;
            document.getElementById('phoneNumber').textContent = user.phone;
            document.getElementById('address').textContent = user.address;
            document.getElementById('driverName').textContent = user.name;

            // Update vehicle info
            document.getElementById('registrationNumber').textContent = driver.ambulanceDetails.registrationNumber;
            document.getElementById('vehicleModel').textContent = driver.ambulanceDetails.model;
            document.getElementById('licenseNumber').textContent = driver.licenseNumber;
            document.getElementById('vehicleCapacity').textContent = driver.ambulanceDetails.capacity;
            document.getElementById('vehicleFeatures').textContent = driver.ambulanceDetails.features.join(', ') || 'None';

            // Update stats
            document.getElementById('rating').textContent = driver.rating.toFixed(1);

            // Populate edit form
            document.getElementById('editPhone').value = user.phone;
            document.getElementById('editAddress').value = user.address;
            document.getElementById('editModel').value = driver.ambulanceDetails.model;
            document.getElementById('editCapacity').value = driver.ambulanceDetails.capacity;
            document.getElementById('editFeatures').value = driver.ambulanceDetails.features.join(', ');
          }
        })
        .catch(error => console.error('Error loading profile:', error));

      // Load total trips
      fetch('/booking/driver')
        .then(response => response.json())
        .then(data => {
          if (data.status === 'success') {
            const completedTrips = data.data.bookings.filter(b => b.status === 'completed').length;
            document.getElementById('totalTrips').textContent = completedTrips;
          }
        })
        .catch(error => console.error('Error loading trips:', error));

      // Handle profile update
      document.getElementById('saveProfileBtn').addEventListener('click', function() {
        const formData = {
          phone: document.getElementById('editPhone').value,
          address: document.getElementById('editAddress').value,
          ambulanceDetails: {
            model: document.getElementById('editModel').value,
            capacity: parseInt(document.getElementById('editCapacity').value),
            features: document.getElementById('editFeatures').value.split(',').map(f => f.trim()).filter(f => f)
          }
        };

        fetch('/driver/profile', {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(formData)
        })
        .then(response => response.json())
        .then(data => {
          if (data.status === 'success') {
            location.reload();
          } else {
            alert(data.message || 'Failed to update profile');
          }
        })
        .catch(error => {
          console.error('Error updating profile:', error);
          alert('Failed to update profile. Please try again.');
        });
      });
    });
  </script>
</body>
</html> 